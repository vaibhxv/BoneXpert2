# ============================================================================
# Sample nginx reverse proxy for a BoneXpert 2.0 VPS deployment.
#
# The NestJS process (pm2: bonexpert-api) listens on 127.0.0.1:3000 and serves
# BOTH the web UI (/) and the API (/api). nginx terminates TLS and forwards
# everything to it. The Python engine stays private on 127.0.0.1:8000.
#
# 1. Point your DNS A record at the server.
# 2. Copy this file to /etc/nginx/sites-available/bonexpert and edit server_name.
# 3. ln -s ../sites-available/bonexpert /etc/nginx/sites-enabled/
# 4. Obtain TLS:  sudo certbot --nginx -d bonexpert.example.com
# 5. nginx -t && systemctl reload nginx
# ============================================================================

server {
    listen 80;
    server_name bonexpert.example.com;

    # Allow large radiograph uploads (mirror MAX_UPLOAD_BYTES).
    client_max_body_size 30M;

    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}

# After running certbot, it will add a `listen 443 ssl` server block and an
# HTTP->HTTPS redirect automatically.
