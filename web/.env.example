# Web UI configuration (build-time). Copy to `.env` only if you need to override.

# API base URL. Leave unset for the default single-origin deployment where the
# NestJS gateway serves this UI and exposes the API at /api.
# Set this only when the API lives on a different origin, e.g.:
# VITE_API_URL=https://api.bonexpert.example.com/api

# Dev-only: where `vite dev` proxies /api to (defaults to http://localhost:3000)
# VITE_API_TARGET=http://localhost:3000
