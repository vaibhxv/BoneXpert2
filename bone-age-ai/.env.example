# ---------------------------------------------------------------------------
# BoneXpert 2.0 - Offline AI Inference Service configuration
# Copy this file to `.env` and adjust as needed. All values have sane defaults.
# ---------------------------------------------------------------------------

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Compute device: "auto" | "cpu" | "cuda" | "mps"
DEVICE=auto

# Model version currently served (matches the folder name under models/<model>/)
MODEL_VERSION=current

# Model identifiers (used only by the download script + reported in responses)
CROP_MODEL_ID=ianpan/bone-age-crop
BONE_AGE_MODEL_ID=ianpan/bone-age

# Crop behaviour
# Extra padding (fraction of bbox side) added around the detected hand.
CROP_PADDING=0.05
# Reject predictions whose derived crop confidence falls below this threshold.
CROP_CONFIDENCE_THRESHOLD=0.30

# Input-validity guardrails (reject non-radiograph uploads).
# Max fraction of coloured pixels before the upload is treated as a colour
# photo rather than an X-ray (real radiographs are ~0).
MAX_COLORFULNESS=0.20
# Minimum fraction of the bone-age probability mass that must fall within
# +/- AGE_CONCENTRATION_WINDOW months of the prediction. Diffuse distributions
# indicate an out-of-distribution (non-hand) image and are rejected.
MIN_AGE_CONCENTRATION=0.70
AGE_CONCENTRATION_WINDOW=18

# Upload limits
MAX_UPLOAD_BYTES=25000000

# Force offline mode for HuggingFace / Transformers (never hit the network).
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
